<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
>
    <Dialog
        id="dlgDocument"
        title="{= ${DocumentDialogData>/Mode} === 'edit' ? ${i18n>editDocument} : ${i18n>addDocument} }"
        draggable="true"
        resizable="true"
        contentWidth="30rem"
    >
        <content>
            <VBox
                class="sapUiSmallMargin"
                renderType="Bare"
            >
                <Label
                    text="{i18n>documentType}"
                    labelFor="selDocType"
                />
                <Select
                    id="selDocType"
                    selectedKey="{DocumentDialogData>/DocType}"
                    items="{ValueHelpData>/DocTypes}"
                    required="true"
                    width="100%"
                    editable="{= ${DocumentDialogData>/Mode} === 'edit' ? false : true }"
                    change="onDocumentDialogDocTypeChange"
                >
                    <core:Item
                        key="{ValueHelpData>key}"
                        text="{= ${ValueHelpData>key} ? ${ValueHelpData>text} + ' (' + (${ValueHelpData>mandatory} ? ${i18n>mandatory} : ${i18n>optional}) + ')' : '' }"
                    />
                </Select>

                <VBox
                    visible="{= ${DocumentDialogData>/DocType} === 'ZPM_MANUAL' }"
                    class="sapUiSmallMarginTop"
                >
                    <MessageStrip
                        text="{i18n>msgReadSignLastPage}"
                        type="Information"
                        showIcon="true"
                        showCloseButton="false"
                    />

                    <Button
                        text="{i18n>downloadManual}"
                        icon="sap-icon://download"
                        type="Transparent"
                        class="sapUiTinyMarginTop"
                        press="onDownloadSupplierManual"
                    />
                </VBox>
                <Label
                    text="{i18n>documentTitle}"
                    required="{= ${DocumentDialogData>/DocType} === 'ZPM_COTHER' }"
                    visible="{= ${DocumentDialogData>/DocType} === 'ZPM_COTHER' }"
                    class="sapUiSmallMarginTop"
                />

                <Input
                    id="inpDocName"
                    value="{DocumentDialogData>/DocName}"
                    maxLength="80"
                    required="{= ${DocumentDialogData>/DocType} === 'ZPM_COTHER' }"
                    visible="{= ${DocumentDialogData>/DocType} === 'ZPM_COTHER' }"
                />
                <Label
                    text="{i18n>validTo}"
                    labelFor="inpValidTo"
                    class="sapUiSmallMarginTop"
                />
                <Input
                    id="inpValidTo"
                    value="{DocumentDialogData>/ValidToText}"
                    valueHelpOnly="true"
                    showValueHelp="true"
                    valueHelpIconSrc="sap-icon://appointment-2"
                    valueHelpRequest="onOpenDocDatePicker"
                    required="true"
                    width="100%"
                />

                <DatePicker
                    id="HiddenDP"
                    hideInput="true"
                    change="onHiddenDocDateChange"
                />

                <Label
                    text="{i18n>attachment}"
                    class="sapUiSmallMarginTop"
                    labelFor="fuDoc"
                />
                <HBox
                    alignItems="Center"
                    justifyContent="SpaceBetween"
                >
                    <Text
                        text="{= ${DocumentDialogData>/FileName} ? ${DocumentDialogData>/FileName} : ${i18n>noFileSelected} }"
                        wrapping="false"
                        width="100%"
                    />
                    <unified:FileUploader
                        required="true"
                        id="fuDoc"
                        buttonOnly="true"
                        buttonText="{i18n>attach}"
                        fileType="pdf"
                        mimeType="application/pdf"
                        sameFilenameAllowed="true"
                        multiple="false"
                        change="onDocFileChange"
                    />
                </HBox>
            </VBox>
        </content>

        <beginButton>
            <Button
                text="{= ${DocumentDialogData>/Mode} === 'edit' ? ${i18n>save} : ${i18n>create} }"
                type="Emphasized"
                press="onDocDlgSave"
            />
        </beginButton>

        <endButton>
            <Button
                text="{i18n>cancel}"
                press="onDocDlgCancel"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
